# Anthropic API Key - get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database Configuration
DATABASE_PATH=database/sales.db

# Supabase Auth - get from supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-key-here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# Application Settings
APP_TITLE=Sales Data Chatbot
CURRENCY_SYMBOL=$
DATE_FORMAT=%Y-%m-%d
